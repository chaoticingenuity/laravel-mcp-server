{
  "name": "chaoticingenuity/laravel-mcp-server",
  "description": "Model Context Protocol (MCP) server implementation for Laravel",
  "keywords": [
    "laravel",
    "mcp",
    "model-context-protocol",
    "ai",
    "server"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Brady Kirby",
      "email": "chaoticingenuity@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/contracts": "^10.0|^11.0",
    "illuminate/support": "^10.0|^11.0",
    "illuminate/http": "^10.0|^11.0",
    "illuminate/database": "^10.0|^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0",
    "phpunit/phpunit": "^10.0",
    "laravel/pint": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "ChaoticIngenuity\\LaravelMCP\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ChaoticIngenuity\\LaravelMCP\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
    "format": "vendor/bin/pint"
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "ChaoticIngenuity\\LaravelMCP\\Providers\\MCPServiceProvider"
      ],
      "aliases": {
        "MCP": "ChaoticIngenuity\\LaravelMCP\\Facades\\MCP"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}