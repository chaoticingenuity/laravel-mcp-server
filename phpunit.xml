<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         failOnRisky="true"
         failOnWarning="true"
         stopOnFailure="false"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="Laravel MCP Server Test Suite">
            <directory>tests</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
        <exclude>
            <directory>src/Console</directory>
            <file>src/Providers/MCPServiceProvider.php</file>
        </exclude>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:2fl+Ktvkdphvz7iMvlH1v7SqgQfgP+8ej/S6WzW3wCE="/>
        <env name="DB_CONNECTION" value="testing"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="CACHE_DRIVER" value="array"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        
        <!-- MCP Test Configuration -->
        <env name="MCP_SERVER_NAME" value="Test MCP Server"/>
        <env name="MCP_SERVER_VERSION" value="1.1.0"/>
        <env name="MCP_LOG_REQUESTS" value="false"/>
        <env name="MCP_LOG_PERFORMANCE" value="false"/>
        <env name="MCP_REQUIRE_HTTPS" value="false"/>
        <env name="MCP_BOUNCER_ENABLED" value="false"/>
    </php>
</phpunit>